{
	"name": "runna",
	"version": "1.0.0",
	"main": "expo-router/entry",
	"scripts": {
		"start": "expo start",
		"android": "expo start --android",
		"ios": "expo start --ios",
		"web": "expo start --web",
		"format": "biome format .",
		"format:fix": "biome check . --fix",
		"test": "jest --watch --coverage=false --changedSince=origin/main",
		"testDebug": "jest -o --watch --coverage=false",
		"testFinal": "jest",
		"updateSnapshots": "jest -u --coverage=false",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"expo": "~55.0.6",
		"expo-constants": "~55.0.7",
		"expo-linking": "~55.0.7",
		"expo-router": "~55.0.5",
		"expo-status-bar": "~55.0.4",
		"react": "19.2.0",
		"react-native": "0.83.2",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@testing-library/react-native": "^13.3.3",
		"@types/jest": "29.5.14",
		"@types/react": "~19.2.2",
		"jest": "~29.7.0",
		"jest-expo": "~55.0.9",
		"typescript": "~5.9.2"
	},
	"private": true,
	"jest": {
		"preset": "jest-expo",
		"collectCoverage": true,
		"collectCoverageFrom": [
			"**/*.{ts,tsx,js,jsx}",
			"!**/coverage/**",
			"!**/node_modules/**",
			"!**/babel.config.js",
			"!**/expo-env.d.ts",
			"!**/.expo/**"
		]
	}
}
