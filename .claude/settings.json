{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/format-fix.sh",
						"timeout": 60
					},
					{
						"type": "command",
						"command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/typecheck.sh",
						"timeout": 60
					}
				]
			}
		]
	}
}
